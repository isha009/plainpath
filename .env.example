# Copy to .env and fill in to use the LIVE Microsoft stack.
# Leave everything blank to run fully offline with the local mock (great for first run + demo dry-runs).

# --- Foundry IQ (agentic knowledge retrieval) ---
# When set, PlainPath grounds answers via Foundry IQ instead of the local mock.
FOUNDRY_IQ_ENDPOINT=
FOUNDRY_IQ_API_KEY=
FOUNDRY_IQ_INDEX=tenant-rights

# --- Azure OpenAI (chat model, runs inside your Azure AI Foundry project) ---
# When set, the agent reasons with your deployed model instead of the deterministic MockLLM.
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# --- OpenAI (optional non-Azure fallback for the chat model) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Server ---
PORT=3000

# Tuning
RETRIEVAL_TOP_K=4
GROUNDING_MIN_SCORE=0.12
